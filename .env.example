# ─────────────────────────────────────────────────────────
# GrammarLanguages Backend — Environment Variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────
# Local:
DATABASE_URL="postgresql://postgres:password@localhost:5432/grammarlangs_dev?schema=public"
# Neon.tech (production):
# DATABASE_URL="postgresql://USER:PASS@HOST/grammarlangs?sslmode=require"

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_64_BYTE_HEX_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── AI — Phase 3 (optional) ───────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Cloudflare R2 — Phase 3 (optional) ───────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=grammarlangs-audio
